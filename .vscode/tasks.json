{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "setup: venv + deps",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "if [ ! -d venv ]; then python3 -m venv venv; fi && source venv/bin/activate && pip install -r requirements.txt"
      ],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "frontend: install",
      "type": "shell",
      "command": "npm install",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "dev" }
    },
    {
      "label": "frontend: build",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": []
    },
    {
      "label": "backend: run (uvicorn)",
      "type": "shell",
      "command": "${workspaceFolder}/venv/bin/uvicorn main:app --host 0.0.0.0 --port 7010 --reload",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "dev" }
    },
    {
      "label": "dev: full stack",
      "dependsOn": ["backend: run (uvicorn)", "frontend: dev"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}
